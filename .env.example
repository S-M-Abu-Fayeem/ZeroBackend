# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zero_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection pool sizing
DB_MIN_CONN=2
DB_MAX_CONN=10

# Rerun Migrations (set to true on first run, then false)
RERUN_MIGRATIONS=false

# JWT Secret Key (change this in production!)
SECRET_KEY=your-secret-key-change-in-production-use-random-string

# AI providers (use free-tier-first defaults)
HUGGINGFACE_API_KEY=your_hf_token_here
GROQ_API_KEY=your_groq_key_here

# Free-cost control flags
AI_FREE_ONLY_MODE=true
ALLOW_GROQ_FALLBACK=false
USE_FREE_VISION=true

# Hugging Face router configuration for image-text-to-text
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions
HF_VISION_MODEL=zai-org/GLM-4.5V:cheapest

# Optional Groq model configs (used only if ALLOW_GROQ_FALLBACK=true)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Input guardrail
MAX_IMAGE_BYTES=8388608
